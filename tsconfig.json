{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "removeComments": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    
    /* Fixed path alias without baseUrl */
    "paths": {
      "@/*": ["./src/*"]
    },
    "typeRoots": ["./src/types"],

    "lib": ["ESNext"],
    "target": "ES2022",                /* Modern Node.js engine target */
    "module": "NodeNext",              /* Standard for modern Node.js backends */
    "moduleDetection": "force",
    "allowJs": true,

    /* Native Node.js backend configuration */
    "moduleResolution": "NodeNext",    /* Teaches TS how Node actually resolves files */
    "noEmit": false,                   /* CRUCIAL: Instructs tsc to actually output files */

    /* Best practices */
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    /* Strictness flags */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
